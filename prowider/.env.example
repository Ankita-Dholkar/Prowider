# ─── Required ────────────────────────────────────────────────────────────────
# MongoDB connection string (MongoDB Atlas or any MongoDB instance)
# Get a free cluster at https://www.mongodb.com/atlas
#
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
#
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prowider
